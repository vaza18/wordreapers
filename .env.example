# Copy to .env (never commit .env). All keys must use EXPO_PUBLIC_ for Expo client.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
# Also used by npm run firebase:deploy:* (scripts/firebase-deploy.sh)
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# Platform app ids from Firebase Console → Project settings → Your apps (Android / iOS).
# Required for the platform you run/build. Local .env usually has both; CI jobs pass only one.
# Do not use a web app id — App Check tokens are app-scoped.
EXPO_PUBLIC_FIREBASE_APP_ID_ANDROID=
EXPO_PUBLIC_FIREBASE_APP_ID_IOS=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Native Firebase config (project root, gitignored — download from Firebase Console → Project settings)
# google-services.json
# GoogleService-Info.plist

# App Check debug token — Console → App Check → Apps → Android/iOS → ⋮ → Manage debug tokens
# Required for Metro / dev client; optional for sideload prod builds
EXPO_PUBLIC_FIREBASE_APP_CHECK_DEBUG_TOKEN=

# Runtime and with-firebase-extra both use only EXPO_PUBLIC_FIREBASE_APP_CHECK_PRODUCTION
# (not APP_VARIANT). Unset locally → debug App Check. EAS production sets true in eas.json.
# EXPO_PUBLIC_FIREBASE_APP_CHECK_PRODUCTION=true
# EXPO_PUBLIC_FIREBASE_APP_CHECK_PRODUCTION=false

# Dev-only Metro action logs (ignored when __DEV__ is false / production builds).
# Levels: none | error | event | detail | all
# Default in __DEV__ when unset: event (local key multiplayer actions).
# detail/all also log observed remote peer actions; all includes lexicon/submitWord timings.
# EXPO_PUBLIC_LOG_LEVEL=event

# EAS production builds: copy each EXPO_PUBLIC_FIREBASE_* value to GitHub Environment
# `release` secrets (and optionally EAS Secrets) — see docs/release-ci.md
# Include EXPO_PUBLIC_FIREBASE_APP_ID_ANDROID / _IOS for the platforms you build.
# See docs/store/03-expo-eas-setup.md (local, not in git).

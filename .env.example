# Copy to .env (never commit .env). All keys must use EXPO_PUBLIC_ for Expo client.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
# Also used by npm run firebase:deploy:* (scripts/firebase-deploy.sh)
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# EAS production builds: copy each EXPO_PUBLIC_FIREBASE_* value to EAS Secrets
# (eas secret:create --name EXPO_PUBLIC_FIREBASE_API_KEY --value "..." --type string)
# See docs/store/03-expo-eas-setup.md (local, not in git).

{
  "extends": "expo/tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "module": "esnext",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "constants/**/*.ts",
    "hooks/**/*.ts",
    "services/**/*.ts",
    "store/**/*.ts",
    "tests/**/*.ts",
    "i18n/**/*.ts",
    "lib/dictionary/dictionary-index.ts",
    "lib/dictionary/normalize.ts",
    "lib/dictionary/validate-word.ts",
    "lib/dictionary/vesum-tags.ts",
    "lib/game/*.ts",
    "lib/online/**/*.ts",
    "lib/profile/**/*.ts",
    "lib/feedback/**/*.ts",
    "lib/settings/**/*.ts",
    "types/assets.d.ts",
    "types/firebase-auth-rn.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}

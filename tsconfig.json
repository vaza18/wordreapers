{
  "extends": "expo/tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "jsx": "react-native",
    "module": "preserve",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./*"],
      "react-native": ["./node_modules/react-native"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "contexts/**/*.tsx",
    "constants/**/*.ts",
    "hooks/**/*.ts",
    "services/**/*.ts",
    "store/**/*.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "i18n/**/*.ts",
    "lib/dictionary/dictionary-index.ts",
    "lib/dictionary/normalize.ts",
    "lib/dictionary/round-playable-lexicon.ts",
    "lib/dictionary/validate-word.ts",
    "lib/dictionary/vesum-tags.ts",
    "lib/game/*.ts",
    "lib/firebase/**/*.ts",
    "lib/online/**/*.ts",
    "lib/profile/**/*.ts",
    "lib/feedback/**/*.ts",
    "lib/settings/**/*.ts",
    "types/assets.d.ts",
    "types/firebase-auth-rn.d.ts",
    "types/react-native-firebase-app-check.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}

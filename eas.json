{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "22.13.0"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "environment": "production",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "preview"
      }
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "environment": "production",
      "android": {
        "buildType": "app-bundle",
        "buildArtifactPaths": ["android/app/build/outputs/mapping/**/mapping.txt"]
      },
      "env": {
        "APP_VARIANT": "production"
      }
    }
  },
  "submit": {
    "production": {},
    "testing": {
      "android": {
        "track": "internal",
        "releaseStatus": "completed",
        "serviceAccountKeyPath": "./.ci/credentials/google-play.json"
      },
      "ios": {
        "ascApiKeyPath": "./.ci/credentials/AuthKey.p8"
      }
    }
  }
}

{
  "name": "wordreapers-functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "mkdir -p lib/data && cp ../assets/generated/dictionaries/uk-uk/base_words.txt lib/data/base_words.uk-uk.txt && tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "bash ../scripts/firebase-deploy.sh --only functions"
  },
  "dependencies": {
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.3.2"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}

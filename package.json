{
  "name": "wordreapers",
  "private": true,
  "type": "module",
  "main": "index.js",
  "scripts": {
    "postinstall": "node scripts/prune-nested-react-native.mjs && npm run legal:bundle && npm run sounds:generate && node scripts/ensure-dictionary.mjs",
    "prepare": "husky",
    "ci:check": "bash scripts/ci-check.sh",
    "prestart": "npm run legal:bundle",
    "pretest": "npm run legal:bundle",
    "start": "REACT_NATIVE_PACKAGER_HOSTNAME=localhost expo start --dev-client --localhost",
    "start:lan": "expo start --dev-client",
    "start:tunnel": "expo start --tunnel --dev-client",
    "android": "bash scripts/run-android.sh",
    "android:check": "bash scripts/check-android-env.sh",
    "ios": "bash scripts/run-ios.sh",
    "ios:device": "bash scripts/run-ios-device.sh",
    "ios:fresh": "IOS_DEVICE_FRESH=1 bash scripts/run-ios.sh",
    "ios:device:fresh": "IOS_DEVICE_FRESH=1 bash scripts/run-ios.sh",
    "ios:device:metro": "rm -f ios/.xcode.env.updates && expo run:ios --device",
    "dict:fetch": "tsx scripts/dictionary/fetch-vesum.ts",
    "dict:fetch:latest": "tsx scripts/dictionary/fetch-vesum.ts --latest",
    "dict:build": "tsx scripts/dictionary/build-dictionary.ts",
    "dict:all": "npm run dict:fetch && npm run dict:build",
    "dict:ensure": "node scripts/ensure-dictionary.mjs",
    "dict:validate": "tsx scripts/dictionary/run-validation-tests.ts",
    "dict:review-sample": "tsx scripts/dictionary/generate-review-sample.ts",
    "legal:bundle": "tsx scripts/bundle-legal-docs.ts",
    "legal:pages": "tsx scripts/build-legal-pages.ts",
    "icons:generate": "tsx scripts/generate-app-icons.ts",
    "icons:adaptive": "tsx scripts/generate-adaptive-icon.ts",
    "eas-build-post-install": "npm run dict:ensure",
    "eas-build-pre-install": "npm install -g npm@11.6.2",
    "sounds:generate": "tsx scripts/generate-feedback-sounds.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:rules": "npx firebase-tools emulators:exec --only database --project wordreapers-rules-test \"VITEST_RULES=1 vitest run tests/firebase/database.rules.test.ts\"",
    "qa:round-two-vote": "vitest run tests/online-round-two-vote-scenario.test.ts && npm run test:rules",
    "test:coverage": "vitest run --coverage",
    "test:critical": "npm run test:coverage && node scripts/check-critical-coverage.mjs",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "firebase:login": "npx firebase-tools login",
    "firebase:deploy:rules": "bash scripts/firebase-deploy.sh --only database",
    "firebase:deploy:functions": "bash scripts/firebase-deploy.sh --only functions",
    "firebase:deploy:backend": "bash scripts/firebase-deploy.sh --only database,functions",
    "firebase:purge-orphans": "node scripts/purge-orphan-sessions.mjs",
    "build:android": "bash scripts/eas-build-android-local.sh",
    "build:android:dev": "eas build --platform android --profile development",
    "build:ios": "bash scripts/eas-build-ios-local.sh"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^14.0.1",
    "@types/node": "^22.15.29",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-preset-expo": "~57.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.0.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "firebase-tools": "^14.27.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "react-native-web": "^0.21.2",
    "react-test-renderer": "^19.2.3",
    "sharp": "^0.34.5",
    "tsx": "^4.19.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/app": "^25.1.0",
    "@react-native-firebase/app-check": "^25.1.0",
    "expo": "^57.0.0",
    "expo-application": "~57.0.0",
    "expo-asset": "~57.0.3",
    "expo-audio": "~57.0.0",
    "expo-build-properties": "~57.0.3",
    "expo-camera": "~57.0.1",
    "expo-constants": "~57.0.3",
    "expo-dev-client": "~57.0.5",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-keep-awake": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-localization": "~57.0.0",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "firebase": "^12.15.0",
    "i18next": "^26.3.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.86.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-popover-view": "^6.1.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "zustand": "^5.0.14"
  },
  "overrides": {
    "uuid": "11.1.1",
    "postcss": "8.5.15",
    "markdown-it": "14.2.0",
    "js-yaml": "4.2.0"
  },
  "packageManager": "npm@11.6.2",
  "version": "1.4.0"
}

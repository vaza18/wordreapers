{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "react-native",
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "lib/**/*.ts",
    "vitest.config.ts",
    "types/assets.d.ts",
    "types/firebase-auth-rn.d.ts"
  ],
  "exclude": ["app", "components", "constants", "store", "i18n"]
}
